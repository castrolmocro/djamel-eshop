# =============================================================
#  Djamel E Shop — Environment Variables Template
#  Copy this file to .env and fill in your Supabase values.
#  Get these from: https://supabase.com → Project Settings → API
# =============================================================

# --- Supabase (Backend) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret — found in Supabase Dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# --- Supabase (Frontend / Vite) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Database (Supabase PostgreSQL) ---
# Format: postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# --- Server ---
PORT=8080
NODE_ENV=development

# --- Frontend ---
# Leave blank in development (Vite proxy handles /api → localhost:8080)
VITE_API_URL=
