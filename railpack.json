{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "pnpm install --no-frozen-lockfile"
      ]
    },
    "build": {
      "commands": [
        "pnpm --filter @workspace/djamel-eshop build"
      ]
    }
  },
  "deploy": {
    "spaOutputDir": "artifacts/djamel-eshop/dist/public"
  }
}
